{
	"include": ["canopener.h","pk-canopener.h"],
	"classes": {
		"Bus": {
			"namespace": "canopener",
			"constructible": false,
			//"ctorArgs": ["int","int"],
			"methods": {
				"writeSlcan": {"args": ["string"]}
			},
			"events": {
				"slcan": {"args": ["string"], "dispatcher": "slcanDispatcher"}
			}
		},
		"Entry": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"setInt": {"args": ["int"]},
				"getInt": {"return": "int"},
				"refresh": {},
			},
			"events": {
				"change": {"dispatcher": "changeDispatcher"}
			}
		},
		"RemoteDevice": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"at": {"args":["int","int"],"return": "Entry"},
				"insert": {"args":["int","int"],"return": "Entry"},
				"getState": {"return": "string"},
				"flush": {"return": "FlushPromise"}
			},
			"events": {
				"stateChange": {"dispatcher": "stateChangeEvent", "args": ["string"]}
			}
		},
		"FlushPromise": {
			"namespace": "canopener",
			"constructible": false,
			"events": {
				"flush": {"dispatcher": "flushEvent"}
			}
		},
		"MasterDevice": {
			"namespace": "canopener",
			"ctorArgs": ["Bus"],
			"methods": {
				"createRemoteDevice": {"args":["int"],"return": "RemoteDevice"},
				"getRemoteDevice": {"args":["int"],"return": "RemoteDevice"}
			}
		},
		"MockBus": {
			"namespace": "canopener",
			"extends": "Bus",
		}
	},
	"functions": {
		"initEspBus": {"args": ["int","int"], "ifdef": "PEAKERNEL"},
		"getBus": {"return": "Bus", "ifdef": "PEAKERNEL"},
	}
}