{
	"include": ["canopener.h","pk-canopener.h"],
	"classes": {
		"Bus": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"writeSlcan": {"args": ["string"]},
				"writeData": {"args": ["int","buffer"]},
				"loop": {},
				"getTimeout": {"return": "int"},
			},
			"events": {
				"slcan": {"args": ["string"], "dispatcher": "slcanDispatcher"},
				"data": {"args": ["int","buffer"], "dispatcher": "dataDispatcher"}
			}
		},
		"Entry": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"setInt": {"args": ["int"]},
				"getInt": {"return": "int"},
				"setString": {"args": ["string"]},
				"setTypeString": {"args": ["string"], "return": "Entry"},
				"refresh": {},
			},
			"events": {
				"change": {"dispatcher": "changeDispatcher"}
			}
		},
		"RemoteDevice": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"at": {"args":["int","int"],"return": "Entry"},
				"insert": {"args":["int","int"],"return": "Entry"},
				"getState": {"return": "string"},
				"flush": {"return": {"type": "void", "promise": true}},
			},
			"events": {
				"stateChange": {"dispatcher": "stateChangeEvent", "args": ["string"]}
			}
		},
		"IntArray": {
			"namespace": "canopener",
			"constructible": false,
			"methods": {
				"size": {"return": "int"},
				"at": {"return": "int", "args": ["int"]}
			}
		},
		"MasterDevice": {
			"namespace": "canopener",
			"ctorArgs": ["Bus"],
			"methods": {
				"createRemoteDevice": {"args": ["int"],"return": "RemoteDevice"},
				"getRemoteDevice": {"args": ["int"],"return": "RemoteDevice"},
				"getConnectedDeviceIds": {"return": "IntArray"}
			},
			"events": {
				"devicesChanged": {"dispatcher": "devicesChangedEvent"}
			}
		},
		"Device": {
			"namespace": "canopener",
			"ctorArgs": ["Bus"],
			"methods": {
				"setNodeId": {"args": ["int"]},
				"at": {"args":["int","int"],"return": "Entry"},
				"insert": {"args":["int","int"],"return": "Entry"},
			}
		},
		"MockBus": {
			"namespace": "canopener",
			"extends": "Bus",
			"methods": {
				"tickMockMillis": {"args": ["int"]}
			},
			"events": {
				"slcan": {"args": ["string"], "dispatcher": "slcanDispatcher"}
			}
		},
		"BusPair": {
			"namespace": "canopener",
			"methods": {
				"getFirst": {"return": "Bus"},
				"getSecond": {"return": "Bus"},
			},
		}
	},
	"functions": {
		"initEspBus": {"args": ["int","int"], "ifdef": "PEAKERNEL"},
		"getBus": {"return": "Bus", "ifdef": "PEAKERNEL"},
	}
}